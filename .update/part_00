+def registered_analysis_names() -> list[str]:
+    """Return registered analysis/operation identifiers in creation order."""
+    names: list[str] = []
+    for entry in st.session_state.settings_log:
+        name = entry.get("name")
+        if name and name not in names:
+            names.append(name)
+    return names
